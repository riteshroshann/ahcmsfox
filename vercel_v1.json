{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://ahcms.onrender.com/api/:path*" },
    { "source": "/:match*",    "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "DENY" }
      ]
    }
  ]
}
